{
    "id": "org.kde.labplot",
    "branch": "master",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "base": "io.qt.PySide.BaseApp",
    "base-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "labplot",
    "tags": ["nightly"],
    "desktop-file-name-suffix": " (Nightly)",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.llvm21"
    ],
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=x11",
	"--socket=cups",
	"--socket=session-bus",
        "--device=dri",
        "--filesystem=host",
        "--filesystem=/tmp",
        "--filesystem=xdg-documents",
        "--system-talk-name=org.freedesktop.UDisks2",
        "--talk-name=org.freedesktop.Flatpak"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/lib/pkgconfig",
        "/lib/*.la",
        "/lib/*.a",
        "/mkspecs",
        "/share/aclocal",
        "/share/info",
        "/share/doc",
        "/share/man",
        "/share/qlogging-categories6"
    ],
    "cleanup-commands": [
        "/app/cleanup-BaseApp.sh"
    ],
    "modules": [
         {
            "name": "clang-headers",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p ${FLATPAK_DEST}/lib/clang/21/include",
                "cp -r /usr/lib/sdk/llvm21/lib/clang/21/include ${FLATPAK_DEST}/lib/clang/21/"
            ]
        },
        {
            "name": "eigen",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://gitlab.com/libeigen/eigen/-/archive/5.0.1/eigen-5.0.1.tar.bz2",
                    "sha256": "e4de6b08f33fd8b8985d2f204381408c660bffa6170ac65b68ae1bd3cd575c0a"
                }
            ]
        },
        {
            "name": "poppler",
            "config-opts": [
                "-DENABLE_TESTING=OFF",
                "-DENABLE_UNSTABLE_API_ABI_HEADERS=ON",
                "-DENABLE_CPP=OFF",
                "-DENABLE_GLIB=OFF",
                "-DENABLE_GOBJECT_INTROSPECTION=OFF",
                "-DENABLE_UTILS=OFF",
                "-DENABLE_QT5=OFF",
                "-DENABLE_QT6=ON"
            ],
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://poppler.freedesktop.org/poppler-26.07.0.tar.xz",
                    "sha256": "304832f48f8a47fdca90c6b6d1f684e68f37c10c9a0726f345f4ca9df4ca01e2"
                }
            ],
            "modules": [
                {
                    "name": "boost",
                    "buildsystem": "simple",
                    "build-commands": [
                        "./bootstrap.sh --prefix=/app --with-libraries=system,iostreams,program_options,filesystem,date_time",
                        "./b2 -j $FLATPAK_BUILDER_N_JOBS install"
                    ],
                    "sources": [
                        {
                            "type": "archive",
                            "url": "https://archives.boost.io/release/1.88.0/source/boost_1_88_0.tar.bz2",
                            "sha256": "46d9d2c06637b219270877c9e16155cbd015b6dc84349af064c088e9b5b12f7b"
                        }
                    ]
                }
            ],
            "cleanup": [ "/include", "/lib/pkgconfig" ]
        },
        {
            "name": "analitza",
            "buildsystem": "cmake-ninja",
            "sources": [
		    {
			    "type": "archive",
			    "url": "https://download.kde.org/stable/release-service/26.04.3/src/analitza-26.04.3.tar.xz",
			    "sha256": "615b7c244a5baee0be5214c53b8ce37d0a54e69a6fd6b8438c30d7fda45b0746"
		    }
	    ]
        },
        {
            "name": "cantor",
            "buildsystem": "cmake-ninja",
            "sources": [
		    {
			    "type": "archive",
			    "url": "https://download.kde.org/stable/release-service/26.04.3/src/cantor-26.04.3.tar.xz",
			    "sha256": "f0e9734410070b6ecb54dfe042862405b4ef01d65533c0be0386d13b9fdf7250"
		    }
	    ]
        },
        {
            "name": "gsl",
            "sources": [
                {
                    "type": "archive",
                    "url": "http://ftpmirror.gnu.org/gnu/gsl/gsl-2.8.tar.gz",
                    "sha256": "6a99eeed15632c6354895b1dd542ed5a855c0f15d9ad1326c6fe2b2c9e423190"
                }
            ]
        },
        {
            "name": "hdf5",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DHDF5_BUILD_TOOLS=OFF"
	    ],
            "cleanup": [
                "/cmake",
                "/share/hdf5_examples"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://support.hdfgroup.org/releases/hdf5/v1_14/v1_14_6/downloads/hdf5-1.14.6.tar.gz",
                    "sha256": "e4defbac30f50d64e1556374aa49e574417c9e72c6b1de7a4ff88c4b1bea6e9b",
		    "strip-components": 2
                }
            ]
        },
        {
            "name": "netcdf",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/Unidata/netcdf-c/archive/v4.10.1.tar.gz",
                    "sha256": "33c27231c478c3b35da7c7758fbdd02da1fe407abcb16ddfe195f69d164f930d"
                }
            ]
        },
        {
            "name": "cfitsio",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://heasarc.gsfc.nasa.gov/FTP/software/fitsio/c/cfitsio-4.6.4.tar.gz",
                    "sha256": "227b637b91c9820ea96f39a65eb087f053de567d82f4338e2884f123f8183c55"
                }
            ]
        },
        {
            "name": "libcerf",
	    "buildsystem": "cmake-ninja",
	    "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://jugit.fz-juelich.de/mlz/lib/cerf/-/archive/v3.3/libcerf-v3.3.tar.gz",
                    "sha256": "7cbece26ad94bd375eb81fee2b540d0ef68bbeb0994358e57bd588173f96b8ec"
                }
            ]
        },
        {
            "name": "qtmqtt",
	    "buildsystem": "cmake-ninja",
	    "builddir": true,
	    "sources": [
		{
                    "type": "archive",
		    "url": "https://github.com/qt/qtmqtt/archive/refs/tags/v6.10.3.tar.gz",
		    "sha256": "a1759284b332f0b498b725be71addbc7f836b221b0c301d5013255606114c2a7"
		}
	    ]
	},
        {
            "name": "kuserfeedback",
	    "buildsystem": "cmake-ninja",
	    "config-opts": [ "-DBUILD_TESTING=OFF", "-DENABLE_DOCS=OFF" ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/frameworks/6.13/kuserfeedback-6.13.0.tar.xz",
                    "sha256": "48c186482fe7a6f1017a7e50b3a16fd7c10c10f7f963c00f32c61bb073404b9a"
                }
            ]
        },
        {
            "name": "readstat",
            "build-options": {
                "env": {
                    "ACLOCAL_PATH": "/usr/share/gettext/m4:/usr/share/aclocal:/app/share/aclocal"
                }
            },
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/WizardMac/ReadStat/archive/v1.1.9.tar.gz",
                    "sha256": "89af7c785a7ae3d9a7af6e64a69028829a429f66a14b1b913be22816dc07ddca"
                },
		{
                    "type": "patch",
                    "path": "admin/patches/readstat-1.1.9.patch"
                }
            ]
        },
	{
            "name": "discount",
            "buildsystem": "simple",
            "build-commands": [
                "./configure.sh --prefix=/app --enable-all-features --with-fenced-code --shared",
                "sed -e 's|/sbin/ldconfig|/sbin/ldconfig -n|' -i librarian.sh",
                "make install"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/Orc/discount/archive/v3.0.0d.tar.gz",
                    "sha256": "0ed8cc27ac5d46dc6a8beedd5e5673ac8b466a6474bdb7d35f37c815f670385f"
                }
            ]
        },
        {
            "name": "matio",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/tbeu/matio/archive/v1.5.30.tar.gz",
                    "sha256": "cd514c42e13bb39477e7d8fdeaa1502014c552a6a53f0678809cce6951db2bc1"
                }
            ]
        },
        {
            "name": "vector_blf",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/Murmele/vector_blf.git",
                    "tag": "2c1a8e649328f2e06ce4d45c6223628bc39fd178",
                    "commit": "2c1a8e649328f2e06ce4d45c6223628bc39fd178"
                }
            ]
        },
        {
            "name": "mdds",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://gitlab.com/api/v4/projects/mdds%2Fmdds/packages/generic/source/3.2.1/mdds-3.2.1.tar.xz",
                    "sha256": "673f5bb94612dbba581fc92b99b5e5dd1a53e29496a5dbc936432f6b0687c112"
                }
            ]
        },
        {
            "name": "ixion",
            "config-opts": [
                "--with-boost=/app"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://gitlab.com/ixion/ixion/-/archive/0.20.0/ixion-0.20.0.tar.bz2",
                    "sha256": "39e54cd486fed458c2a6e83a5e658d4c2e818862355b33645bb1342449428463"
                }
            ]
        },
        {
            "name": "orcus",
            "config-opts": [
                "--with-boost=/app"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://gitlab.com/orcus/orcus/-/archive/0.21.0/orcus-0.21.0.tar.bz2",
                    "sha256": "3555660197d6d38d720643f430804bb0f95a484c1fe6c28c00808ae67f978d15"
                }
            ]
        },
        {
            "name": "QXlsx",
            "buildsystem": "cmake-ninja",
            "subdir": "QXlsx",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/QtExcel/QXlsx/archive/refs/tags/v1.5.0.tar.gz",
                    "sha256": "4461bb0fc9b88b6a970520e8b32eb7d2fc391a1a5c326b139a0af836278cdb09"
                },
                {
                    "type": "patch",
                    "path": "admin/patches/QXlsx-1.5.0.patch"
                }
            ]
        },
        {
            "name": "labplot",
            "buildsystem": "cmake-ninja",
            "config-opts": [
		    "-DQt6Mqtt_DIR=/app/qtmqtt/usr/lib/x86_64-linux-gnu/cmake/Qt6Mqtt",
		    "-DENABLE_TESTS=OFF",
		    "-DENABLE_COMPILER_OPTIMIZATION=ON"
	    ],
	    "build-options": {
		    "env": {
			    "CLANG_INSTALL_DIR": "/app"
		    }
	    },
	    "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
	    ],
	    "modules": [
                {
                    "name": "patchelf",
                    "buildsystem": "autotools",
                    "sources": [
                        {
                            "type": "archive",
                            "url": "https://github.com/NixOS/patchelf/releases/download/0.18.0/patchelf-0.18.0.tar.bz2",
                            "sha256": "1952b2a782ba576279c211ee942e341748fdb44997f704dd53def46cd055470b"
                        }
                    ]
                }
            ]
        }
    ]
}
